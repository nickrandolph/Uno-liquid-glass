<!--
  LiquidGlass.Uno — Common.xaml
  Theme-agnostic design tokens: shapes, metrics, typography.

  Liquid Glass shape rules: standard buttons are capsules; container radii are
  "concentric" — a nested element's radius = container radius − inset padding.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Corner radii -->
  <CornerRadius x:Key="ControlCornerRadius">10</CornerRadius>
  <CornerRadius x:Key="OverlayCornerRadius">26</CornerRadius>
  <CornerRadius x:Key="LiquidGlassCapsuleCornerRadius">22</CornerRadius>
  <CornerRadius x:Key="LiquidGlassCardCornerRadius">26</CornerRadius>
  <!-- Concentric: card radius (26) − card padding (16) = 10 for nested controls -->
  <CornerRadius x:Key="LiquidGlassNestedCornerRadius">10</CornerRadius>

  <!-- Metrics: Apple minimum touch target is 44pt; capsule = MinHeight / 2 -->
  <x:Double x:Key="LiquidGlassControlMinHeight">44</x:Double>
  <Thickness x:Key="LiquidGlassButtonPadding">20,10,20,11</Thickness>
  <Thickness x:Key="LiquidGlassCardPadding">16</Thickness>
  <x:Double x:Key="LiquidGlassStrokeThickness">1</x:Double>

  <!-- Typography -->
  <FontFamily x:Key="LiquidGlassFontFamily">Helvetica Neue</FontFamily>
  <x:Double x:Key="LiquidGlassBodyFontSize">15</x:Double>
  <x:Double x:Key="LiquidGlassCalloutFontSize">16</x:Double>
  <x:Double x:Key="LiquidGlassTitleFontSize">22</x:Double>
  <x:Double x:Key="LiquidGlassLargeTitleFontSize">34</x:Double>
</ResourceDictionary>
