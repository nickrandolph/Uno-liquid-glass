<!--
  LiquidGlass.Uno — Colors.xaml
  Palette + glass material brushes implementing Apple's Liquid Glass design language.
  https://developer.apple.com/documentation/technologyoverviews/adopting-liquid-glass

  Structure mirrors Uno.Themes (Uno.Material): all theme-scoped resources live in
  ThemeDictionaries (Light / Default=Dark) so ThemeResource lookups adapt to the OS theme.

  NOTE on the lightweight styling override sections: on Uno, stock Fluent templates
  resolve these keys in FRAMEWORK scope when the control sits directly in a page —
  there the overrides do nothing and the theme's full retemplates carry the look.
  BUT a stock-templated control hosted INSIDE a library-compiled template (e.g. a
  ToggleSwitch set as a Windows Community Toolkit SettingsCard's Content) resolves
  them through APP scope, where these overrides DO apply. They are load-bearing for
  that hosting context (verified 2026-07-15: removing ToggleSwitchFillOn turned the
  WCT settings toggle stock-blue) — do not remove them as "dead".
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ResourceDictionary.ThemeDictionaries>

    <!-- ================================ LIGHT ================================ -->
    <ResourceDictionary x:Key="Light">

      <!-- Apple system palette -->
      <Color x:Key="LiquidGlassTintColor">#007AFF</Color>
      <Color x:Key="LiquidGlassTintPressedColor">#0066D6</Color>
      <Color x:Key="LiquidGlassSuccessColor">#34C759</Color>
      <Color x:Key="LiquidGlassDestructiveColor">#FF3B30</Color>

      <!-- Make the WinUI accent follow the Apple tint -->
      <Color x:Key="SystemAccentColor">#007AFF</Color>
      <Color x:Key="SystemAccentColorLight1">#3395FF</Color>
      <Color x:Key="SystemAccentColorLight2">#66B0FF</Color>
      <Color x:Key="SystemAccentColorLight3">#99CAFF</Color>
      <Color x:Key="SystemAccentColorDark1">#0066D6</Color>
      <Color x:Key="SystemAccentColorDark2">#0055B3</Color>
      <Color x:Key="SystemAccentColorDark3">#004494</Color>

      <SolidColorBrush x:Key="LiquidGlassTintBrush" Color="#007AFF" />
      <SolidColorBrush x:Key="LiquidGlassTintPressedBrush" Color="#0066D6" />
      <SolidColorBrush x:Key="LiquidGlassOnTintBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="LiquidGlassSuccessBrush" Color="#34C759" />
      <SolidColorBrush x:Key="LiquidGlassDestructiveBrush" Color="#FF3B30" />

      <!-- Labels (Apple label / secondaryLabel / tertiaryLabel) -->
      <SolidColorBrush x:Key="LiquidGlassLabelBrush" Color="#000000" />
      <SolidColorBrush x:Key="LiquidGlassSecondaryLabelBrush" Color="#993C3C43" />
      <SolidColorBrush x:Key="LiquidGlassTertiaryLabelBrush" Color="#4D3C3C43" />
      <SolidColorBrush x:Key="LiquidGlassSeparatorBrush" Color="#5C3C3C43" />

      <!-- ======== Liquid Glass materials ========
           Regular glass: adaptive translucent material. AcrylicBrush gives real backdrop
           blur where supported; FallbackColor keeps translucency elsewhere. -->
      <AcrylicBrush x:Key="LiquidGlassFillBrush"
                    TintColor="#F5F5F7" TintOpacity="0.45"
                    FallbackColor="#B8FFFFFF" />
      <AcrylicBrush x:Key="LiquidGlassFillPointerOverBrush"
                    TintColor="#FFFFFF" TintOpacity="0.55"
                    FallbackColor="#CCFFFFFF" />
      <AcrylicBrush x:Key="LiquidGlassFillPressedBrush"
                    TintColor="#E5E5EA" TintOpacity="0.6"
                    FallbackColor="#D9E5E5EA" />

      <!-- Clear glass: for controls sitting on media-rich content -->
      <AcrylicBrush x:Key="LiquidGlassClearFillBrush"
                    TintColor="#FFFFFF" TintOpacity="0.15"
                    FallbackColor="#40FFFFFF" />

      <!-- Subtle fill for text inputs -->
      <AcrylicBrush x:Key="LiquidGlassControlFillBrush"
                    TintColor="#FFFFFF" TintOpacity="0.3"
                    FallbackColor="#8CFFFFFF" />

      <!-- Heavier material for panes, flyouts, dialogs -->
      <AcrylicBrush x:Key="LiquidGlassSurfaceBrush"
                    TintColor="#F5F5F7" TintOpacity="0.7"
                    FallbackColor="#E6F5F5F7" />

      <!-- Sidebar material: frostier, lets the content layer extend underneath -->
      <AcrylicBrush x:Key="LiquidGlassPaneBrush"
                    TintColor="#F5F5F7" TintOpacity="0.35"
                    FallbackColor="#CCF2F2F7" />

      <!-- Specular rim light: bright top edge fading out, faint dark bottom edge -->
      <LinearGradientBrush x:Key="LiquidGlassStrokeBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#B3FFFFFF" />
        <GradientStop Offset="0.5" Color="#33FFFFFF" />
        <GradientStop Offset="1" Color="#21000000" />
      </LinearGradientBrush>

      <!-- Specular highlight wash across the top of the glass -->
      <LinearGradientBrush x:Key="LiquidGlassSpecularBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#73FFFFFF" />
        <GradientStop Offset="0.45" Color="#14FFFFFF" />
        <GradientStop Offset="0.6" Color="#00FFFFFF" />
      </LinearGradientBrush>

      <!-- Prominent (tinted) glass for primary actions -->
      <LinearGradientBrush x:Key="LiquidGlassProminentFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#F2339CFF" />
        <GradientStop Offset="1" Color="#F2007AFF" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="LiquidGlassProminentFillPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#F22B8AE6" />
        <GradientStop Offset="1" Color="#F20066D6" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="LiquidGlassProminentStrokeBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#8CFFFFFF" />
        <GradientStop Offset="1" Color="#1AFFFFFF" />
      </LinearGradientBrush>

      <!-- Interaction overlays -->
      <SolidColorBrush x:Key="LiquidGlassHoverOverlayBrush" Color="#14FFFFFF" />
      <SolidColorBrush x:Key="LiquidGlassPressedOverlayBrush" Color="#1F000000" />
      <!-- Selection band behind the focused row of picker wheels -->
      <SolidColorBrush x:Key="LiquidGlassHighlightBrush" Color="#29787880" />

      <!-- Page background behind the content layer -->
      <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#F2F2F7" />

      <!-- ======== Lightweight styling overrides for stock WinUI templates ========
           Live for stock-templated controls hosted inside library-compiled templates
           (see file header); inert for controls the theme fully retemplates. -->

      <!-- ToggleSwitch: iOS-style green switch on frosted off-track -->
      <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="#34C759" />
      <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="#3ED167" />
      <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="#2DB350" />
      <SolidColorBrush x:Key="ToggleSwitchStrokeOn" Color="Transparent" />
      <SolidColorBrush x:Key="ToggleSwitchStrokeOnPointerOver" Color="Transparent" />
      <SolidColorBrush x:Key="ToggleSwitchStrokeOnPressed" Color="Transparent" />
      <SolidColorBrush x:Key="ToggleSwitchKnobFillOn" Color="#FFFFFF" />
      <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPointerOver" Color="#FFFFFF" />
      <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPressed" Color="#FFFFFF" />
      <SolidColorBrush x:Key="ToggleSwitchFillOff" Color="#52787880" />
      <SolidColorBrush x:Key="ToggleSwitchFillOffPointerOver" Color="#66787880" />
      <SolidColorBrush x:Key="ToggleSwitchFillOffPressed" Color="#7A787880" />
      <SolidColorBrush x:Key="ToggleSwitchStrokeOff" Color="Transparent" />
      <SolidColorBrush x:Key="ToggleSwitchStrokeOffPointerOver" Color="Transparent" />
      <SolidColorBrush x:Key="ToggleSwitchStrokeOffPressed" Color="Transparent" />
      <SolidColorBrush x:Key="ToggleSwitchKnobFillOff" Color="#FFFFFF" />
      <SolidColorBrush x:Key="ToggleSwitchKnobFillOffPointerOver" Color="#FFFFFF" />
      <SolidColorBrush x:Key="ToggleSwitchKnobFillOffPressed" Color="#FFFFFF" />

      <!-- Slider -->
      <SolidColorBrush x:Key="SliderTrackValueFill" Color="#007AFF" />
      <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="#3395FF" />
      <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="#0066D6" />
      <SolidColorBrush x:Key="SliderTrackFill" Color="#3C787880" />
      <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="#52787880" />
      <SolidColorBrush x:Key="SliderTrackFillPressed" Color="#52787880" />
      <SolidColorBrush x:Key="SliderThumbBackground" Color="#FFFFFF" />
      <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="#FFFFFF" />
      <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="#F0F0F0" />

      <!-- CheckBox -->
      <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillUnchecked" Color="#33787880" />
      <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillUncheckedPointerOver" Color="#47787880" />
      <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillUncheckedPressed" Color="#5C787880" />
      <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUnchecked" Color="#5C3C3C43" />
      <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUncheckedPointerOver" Color="#803C3C43" />
      <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUncheckedPressed" Color="#803C3C43" />
      <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillChecked" Color="#007AFF" />
      <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPointerOver" Color="#3395FF" />
      <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPressed" Color="#0066D6" />
      <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeChecked" Color="Transparent" />
      <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeCheckedPointerOver" Color="Transparent" />
      <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeCheckedPressed" Color="Transparent" />
      <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundChecked" Color="#FFFFFF" />
      <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundCheckedPointerOver" Color="#FFFFFF" />
      <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundCheckedPressed" Color="#FFFFFF" />
      <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillIndeterminate" Color="#007AFF" />
      <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillIndeterminatePointerOver" Color="#3395FF" />
      <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillIndeterminatePressed" Color="#0066D6" />
      <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeIndeterminate" Color="Transparent" />
      <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundIndeterminate" Color="#FFFFFF" />

      <!-- RadioButton -->
      <SolidColorBrush x:Key="RadioButtonOuterEllipseFill" Color="#33787880" />
      <SolidColorBrush x:Key="RadioButtonOuterEllipseFillPointerOver" Color="#47787880" />
      <SolidColorBrush x:Key="RadioButtonOuterEllipseFillPressed" Color="#5C787880" />
      <SolidColorBrush x:Key="RadioButtonOuterEllipseStroke" Color="#5C3C3C43" />
      <SolidColorBrush x:Key="RadioButtonOuterEllipseStrokePointerOver" Color="#803C3C43" />
      <SolidColorBrush x:Key="RadioButtonOuterEllipseStrokePressed" Color="#803C3C43" />
      <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedFill" Color="#007AFF" />
      <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedFillPointerOver" Color="#3395FF" />
      <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedFillPressed" Color="#0066D6" />
      <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedStroke" Color="Transparent" />
      <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedStrokePointerOver" Color="Transparent" />
      <SolidColorBrush x:Key="RadioButtonOuterEllipseCheckedStrokePressed" Color="Transparent" />
      <SolidColorBrush x:Key="RadioButtonCheckGlyphFill" Color="#FFFFFF" />
      <SolidColorBrush x:Key="RadioButtonCheckGlyphFillPointerOver" Color="#FFFFFF" />
      <SolidColorBrush x:Key="RadioButtonCheckGlyphFillPressed" Color="#FFFFFF" />

      <!-- Text controls (TextBox, PasswordBox, AutoSuggestBox, NumberBox) -->
      <StaticResource x:Key="TextControlBackground" ResourceKey="LiquidGlassControlFillBrush" />
      <StaticResource x:Key="TextControlBackgroundPointerOver" ResourceKey="LiquidGlassControlFillBrush" />
      <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="LiquidGlassFillPointerOverBrush" />
      <SolidColorBrush x:Key="TextControlBorderBrush" Color="#38FFFFFF" />
      <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#59FFFFFF" />
      <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#007AFF" />
      <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#993C3C43" />
      <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#993C3C43" />
      <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#993C3C43" />
      <Color x:Key="TextControlSelectionHighlightColor">#66007AFF</Color>

      <!-- ComboBox -->
      <StaticResource x:Key="ComboBoxBackground" ResourceKey="LiquidGlassFillBrush" />
      <StaticResource x:Key="ComboBoxBackgroundPointerOver" ResourceKey="LiquidGlassFillPointerOverBrush" />
      <StaticResource x:Key="ComboBoxBackgroundPressed" ResourceKey="LiquidGlassFillPressedBrush" />
      <StaticResource x:Key="ComboBoxBorderBrush" ResourceKey="LiquidGlassStrokeBrush" />
      <StaticResource x:Key="ComboBoxBorderBrushPointerOver" ResourceKey="LiquidGlassStrokeBrush" />
      <StaticResource x:Key="ComboBoxBorderBrushPressed" ResourceKey="LiquidGlassStrokeBrush" />
      <StaticResource x:Key="ComboBoxDropDownBackground" ResourceKey="LiquidGlassSurfaceBrush" />
      <SolidColorBrush x:Key="ComboBoxDropDownGlyphForeground" Color="#993C3C43" />

      <!-- Progress -->
      <SolidColorBrush x:Key="ProgressBarForeground" Color="#007AFF" />
      <SolidColorBrush x:Key="ProgressBarBackground" Color="#3C787880" />
      <SolidColorBrush x:Key="ProgressRingForeground" Color="#007AFF" />
      <SolidColorBrush x:Key="ProgressRingBackground" Color="#3C787880" />

      <!-- HyperlinkButton -->
      <SolidColorBrush x:Key="HyperlinkButtonForeground" Color="#007AFF" />
      <SolidColorBrush x:Key="HyperlinkButtonForegroundPointerOver" Color="#3395FF" />
      <SolidColorBrush x:Key="HyperlinkButtonForegroundPressed" Color="#0066D6" />

      <!-- Lists -->
      <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="#26FFFFFF" />
      <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#33007AFF" />
      <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#40007AFF" />
      <SolidColorBrush x:Key="GridViewItemBackgroundSelected" Color="#33007AFF" />

      <!-- NavigationView: frosted sidebar over the content layer -->
      <StaticResource x:Key="NavigationViewDefaultPaneBackground" ResourceKey="LiquidGlassSurfaceBrush" />
      <StaticResource x:Key="NavigationViewExpandedPaneBackground" ResourceKey="LiquidGlassSurfaceBrush" />
      <StaticResource x:Key="NavigationViewTopPaneBackground" ResourceKey="LiquidGlassSurfaceBrush" />
      <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
      <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="#40FFFFFF" />
      <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver" Color="#59FFFFFF" />
      <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#007AFF" />

      <!-- Flyouts, dialogs, pickers -->
      <StaticResource x:Key="FlyoutPresenterBackground" ResourceKey="LiquidGlassSurfaceBrush" />
      <StaticResource x:Key="MenuFlyoutPresenterBackground" ResourceKey="LiquidGlassSurfaceBrush" />
      <StaticResource x:Key="ContentDialogBackground" ResourceKey="LiquidGlassSurfaceBrush" />
      <StaticResource x:Key="AutoSuggestBoxSuggestionsListBackground" ResourceKey="LiquidGlassSurfaceBrush" />
      <StaticResource x:Key="DatePickerFlyoutPresenterBackground" ResourceKey="LiquidGlassSurfaceBrush" />
      <StaticResource x:Key="TimePickerFlyoutPresenterBackground" ResourceKey="LiquidGlassSurfaceBrush" />
      <StaticResource x:Key="DatePickerButtonBackground" ResourceKey="LiquidGlassFillBrush" />
      <StaticResource x:Key="DatePickerButtonBackgroundPointerOver" ResourceKey="LiquidGlassFillPointerOverBrush" />
      <StaticResource x:Key="DatePickerButtonBackgroundPressed" ResourceKey="LiquidGlassFillPressedBrush" />
      <StaticResource x:Key="TimePickerButtonBackground" ResourceKey="LiquidGlassFillBrush" />
      <StaticResource x:Key="TimePickerButtonBackgroundPointerOver" ResourceKey="LiquidGlassFillPointerOverBrush" />
      <StaticResource x:Key="TimePickerButtonBackgroundPressed" ResourceKey="LiquidGlassFillPressedBrush" />
      <StaticResource x:Key="CalendarDatePickerBackground" ResourceKey="LiquidGlassFillBrush" />
      <StaticResource x:Key="CalendarDatePickerBackgroundPointerOver" ResourceKey="LiquidGlassFillPointerOverBrush" />
      <StaticResource x:Key="CalendarDatePickerBackgroundPressed" ResourceKey="LiquidGlassFillPressedBrush" />
      <StaticResource x:Key="CalendarDatePickerBorderBrush" ResourceKey="LiquidGlassStrokeBrush" />

      <!-- Pivot -->
      <SolidColorBrush x:Key="PivotHeaderItemSelectedForeground" Color="#007AFF" />
      <SolidColorBrush x:Key="PivotHeaderItemUnselectedForeground" Color="#993C3C43" />
      <SolidColorBrush x:Key="PivotHeaderItemSelectedPipeFill" Color="#007AFF" />
    </ResourceDictionary>

    <!-- ================================ DARK ================================ -->
    <ResourceDictionary x:Key="Default">

      <!-- Apple system palette (dark) -->
      <Color x:Key="LiquidGlassTintColor">#0A84FF</Color>
      <Color x:Key="LiquidGlassTintPressedColor">#409CFF</Color>
      <Color x:Key="LiquidGlassSuccessColor">#30D158</Color>
      <Color x:Key="LiquidGlassDestructiveColor">#FF453A</Color>

      <Color x:Key="SystemAccentColor">#0A84FF</Color>
      <Color x:Key="SystemAccentColorLight1">#409CFF</Color>
      <Color x:Key="SystemAccentColorLight2">#70B4FF</Color>
      <Color x:Key="SystemAccentColorLight3">#A3CDFF</Color>
      <Color x:Key="SystemAccentColorDark1">#086CD9</Color>
      <Color x:Key="SystemAccentColorDark2">#0759B3</Color>
      <Color x:Key="SystemAccentColorDark3">#05478C</Color>

      <SolidColorBrush x:Key="LiquidGlassTintBrush" Color="#0A84FF" />
      <SolidColorBrush x:Key="LiquidGlassTintPressedBrush" Color="#409CFF" />
      <SolidColorBrush x:Key="LiquidGlassOnTintBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="LiquidGlassSuccessBrush" Color="#30D158" />
      <SolidColorBrush x:Key="LiquidGlassDestructiveBrush" Color="#FF453A" />

      <SolidColorBrush x:Key="LiquidGlassLabelBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="LiquidGlassSecondaryLabelBrush" Color="#99EBEBF5" />
      <SolidColorBrush x:Key="LiquidGlassTertiaryLabelBrush" Color="#4DEBEBF5" />
      <SolidColorBrush x:Key="LiquidGlassSeparatorBrush" Color="#99545458" />

      <!-- ======== Liquid Glass materials (dark) ======== -->
      <AcrylicBrush x:Key="LiquidGlassFillBrush"
                    TintColor="#1C1C1E" TintOpacity="0.45"
                    FallbackColor="#A63A3A3C" />
      <AcrylicBrush x:Key="LiquidGlassFillPointerOverBrush"
                    TintColor="#2C2C2E" TintOpacity="0.55"
                    FallbackColor="#BF48484A" />
      <AcrylicBrush x:Key="LiquidGlassFillPressedBrush"
                    TintColor="#0F0F10" TintOpacity="0.6"
                    FallbackColor="#CC2C2C2E" />

      <AcrylicBrush x:Key="LiquidGlassClearFillBrush"
                    TintColor="#000000" TintOpacity="0.15"
                    FallbackColor="#40000000" />

      <AcrylicBrush x:Key="LiquidGlassControlFillBrush"
                    TintColor="#1C1C1E" TintOpacity="0.3"
                    FallbackColor="#66767680" />

      <AcrylicBrush x:Key="LiquidGlassSurfaceBrush"
                    TintColor="#1C1C1E" TintOpacity="0.7"
                    FallbackColor="#E62C2C2E" />

      <!-- Sidebar material: frostier, lets the content layer extend underneath -->
      <AcrylicBrush x:Key="LiquidGlassPaneBrush"
                    TintColor="#1C1C1E" TintOpacity="0.35"
                    FallbackColor="#CC28282A" />

      <LinearGradientBrush x:Key="LiquidGlassStrokeBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#59FFFFFF" />
        <GradientStop Offset="0.5" Color="#1FFFFFFF" />
        <GradientStop Offset="1" Color="#40000000" />
      </LinearGradientBrush>

      <LinearGradientBrush x:Key="LiquidGlassSpecularBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#40FFFFFF" />
        <GradientStop Offset="0.45" Color="#0DFFFFFF" />
        <GradientStop Offset="0.6" Color="#00FFFFFF" />
      </LinearGradientBrush>

      <LinearGradientBrush x:Key="LiquidGlassProminentFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#F2409CFF" />
        <GradientStop Offset="1" Color="#F20A84FF" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="LiquidGlassProminentFillPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#F23A8CE6" />
        <GradientStop Offset="1" Color="#F20973E0" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="LiquidGlassProminentStrokeBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#66FFFFFF" />
        <GradientStop Offset="1" Color="#14FFFFFF" />
      </LinearGradientBrush>

      <SolidColorBrush x:Key="LiquidGlassHoverOverlayBrush" Color="#14FFFFFF" />
      <SolidColorBrush x:Key="LiquidGlassPressedOverlayBrush" Color="#1FFFFFFF" />
      <!-- Selection band behind the focused row of picker wheels -->
