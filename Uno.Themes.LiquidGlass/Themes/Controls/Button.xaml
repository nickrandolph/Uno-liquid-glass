  <!-- ============================ HyperlinkButton ============================ -->
  <Style x:Key="LiquidGlassHyperlinkButtonStyle" TargetType="HyperlinkButton">
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassTintBrush}" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="MinHeight" Value="44" />
  </Style>
</ResourceDictionary>
