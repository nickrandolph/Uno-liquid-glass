<!--
  LiquidGlass.Uno — InputsStatus.xaml
  Glass templates for stock WinUI input/status controls: NumberBox, RatingControl,
  InfoBar, ToolTip, InfoBadge, PersonPicture.

  Approach follows the rest of the theme: full retemplates keeping the canonical
  template part names and VisualStateGroup/state names (Uno's control code finds
  parts via GetTemplateChild and drives states via GoToState), with visual states
  using opacity-toggled overlays or plain value setters — never brush-swap
  storyboard keyframes.

  RatingControl's unset-star colors are resolved from code by resource key
  (RatingControl*Foreground), so those lightweight keys are also provided in the
  ThemeDictionaries below as a belt-and-suspenders alongside the template states.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives">

  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <!-- Apple systemOrange: the palette has no warning brush -->
      <SolidColorBrush x:Key="LiquidGlassWarningBrush" Color="#FF9F0A" />

      <!-- RatingControl star colors are looked up from control code by key -->
      <SolidColorBrush x:Key="RatingControlSelectedForeground" Color="#007AFF" />
      <SolidColorBrush x:Key="RatingControlUnselectedForeground" Color="#4D3C3C43" />
      <SolidColorBrush x:Key="RatingControlPointerOverUnselectedForeground" Color="#80007AFF" />
      <SolidColorBrush x:Key="RatingControlPlaceholderForeground" Color="#007AFF" />
      <SolidColorBrush x:Key="RatingControlPointerOverPlaceholderForeground" Color="#3395FF" />
      <SolidColorBrush x:Key="RatingControlDisabledSelectedForeground" Color="#4D3C3C43" />
      <SolidColorBrush x:Key="RatingControlCaptionForeground" Color="#993C3C43" />
    </ResourceDictionary>
    <ResourceDictionary x:Key="Default">
      <SolidColorBrush x:Key="LiquidGlassWarningBrush" Color="#FF9F0A" />

      <SolidColorBrush x:Key="RatingControlSelectedForeground" Color="#0A84FF" />
      <SolidColorBrush x:Key="RatingControlUnselectedForeground" Color="#4DEBEBF5" />
      <SolidColorBrush x:Key="RatingControlPointerOverUnselectedForeground" Color="#800A84FF" />
      <SolidColorBrush x:Key="RatingControlPlaceholderForeground" Color="#0A84FF" />
      <SolidColorBrush x:Key="RatingControlPointerOverPlaceholderForeground" Color="#409CFF" />
      <SolidColorBrush x:Key="RatingControlDisabledSelectedForeground" Color="#4DEBEBF5" />
      <SolidColorBrush x:Key="RatingControlCaptionForeground" Color="#99EBEBF5" />
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>

  <!-- ============================== NumberBox ============================== -->

  <!-- Chromeless glyph spin button, hover/press as opacity overlays -->
  <Style x:Key="LiquidGlassSpinButtonStyle" TargetType="RepeatButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Width" Value="30" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RepeatButton">
          <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="PointerOver">
                  <VisualState.Setters>
                    <Setter Target="HoverFill.Opacity" Value="1" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Pressed">
                  <VisualState.Setters>
                    <Setter Target="PressedFill.Opacity" Value="1" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Disabled">
                  <VisualState.Setters>
                    <Setter Target="RootGrid.Opacity" Value="0.3" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Border x:Name="HoverFill"
                    Background="{ThemeResource LiquidGlassHoverOverlayBrush}"
                    CornerRadius="7"
                    Opacity="0" />
            <Border x:Name="PressedFill"
                    Background="{ThemeResource LiquidGlassPressedOverlayBrush}"
                    CornerRadius="7"
                    Opacity="0" />
            <ContentPresenter x:Name="ContentPresenter"
                              Content="{TemplateBinding Content}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              AutomationProperties.AccessibilityView="Raw" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- The glass field hosted inside NumberBox (same look as LiquidGlassTextBoxStyle;
       duplicated here so this dictionary stays self-contained) -->
  <Style x:Key="LiquidGlassNumberBoxInputBoxStyle" TargetType="TextBox">
    <Setter Property="Background" Value="{ThemeResource LiquidGlassControlFillBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassLabelBrush}" />
    <Setter Property="PlaceholderForeground" Value="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
    <Setter Property="SelectionHighlightColor" Value="{ThemeResource LiquidGlassTintColor}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Padding" Value="14,9,14,10" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Grid>
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="PointerOver">
                  <VisualState.Setters>
                    <Setter Target="BorderElement.Background" Value="{ThemeResource LiquidGlassFillPointerOverBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Focused">
                  <VisualState.Setters>
                    <Setter Target="BorderElement.Background" Value="{ThemeResource LiquidGlassFillPointerOverBrush}" />
                    <Setter Target="FocusRim.BorderBrush" Value="{ThemeResource LiquidGlassTintBrush}" />
                    <Setter Target="FocusRim.Opacity" Value="1" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Disabled">
                  <VisualState.Setters>
                    <Setter Target="BorderElement.Opacity" Value="0.45" />
                    <Setter Target="ContentElement.Opacity" Value="0.45" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Grid MinHeight="{TemplateBinding MinHeight}">
              <Border x:Name="BorderElement"
                      Background="{TemplateBinding Background}"
                      CornerRadius="{TemplateBinding CornerRadius}" />
              <Border x:Name="Rim"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="{TemplateBinding CornerRadius}"
                      IsHitTestVisible="False" />
              <Border x:Name="FocusRim"
                      BorderThickness="1.5"
                      CornerRadius="{TemplateBinding CornerRadius}"
                      Opacity="0"
                      IsHitTestVisible="False" />

              <ScrollViewer x:Name="ContentElement"
                            Padding="{TemplateBinding Padding}"
                            HorizontalScrollMode="Auto"
                            HorizontalScrollBarVisibility="Hidden"
                            VerticalScrollMode="Auto"
                            VerticalScrollBarVisibility="Hidden"
                            IsTabStop="False"
                            ZoomMode="Disabled"
                            AutomationProperties.AccessibilityView="Raw"
                            VerticalAlignment="Center" />
              <TextBlock x:Name="PlaceholderTextContentPresenter"
                         Text="{TemplateBinding PlaceholderText}"
                         Foreground="{TemplateBinding PlaceholderForeground}"
                         Padding="{TemplateBinding Padding}"
                         VerticalAlignment="Center"
                         IsHitTestVisible="False" />
            </Grid>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- NumberBox: glass field with inline chromeless spin buttons. Canonical parts
       kept: InputBox, UpSpinButton, DownSpinButton, InputEater, UpDownPopup,
       PopupUpSpinButton, PopupDownSpinButton, HeaderContentPresenter,
       DescriptionPresenter. The Compact (popup) mode keeps its parts but skips
       the stock popup-indicator glyph. -->
  <Style x:Key="LiquidGlassNumberBoxStyle" TargetType="NumberBox">
    <Setter Property="Background" Value="{ThemeResource LiquidGlassControlFillBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassLabelBrush}" />
    <Setter Property="SelectionHighlightColor" Value="{ThemeResource LiquidGlassTintColor}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Padding" Value="14,9,14,10" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="SpinButtonPlacementMode" Value="Inline" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="NumberBox">
          <Grid>
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="Disabled">
                  <VisualState.Setters>
                    <Setter Target="HeaderContentPresenter.Opacity" Value="0.45" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
              <VisualStateGroup x:Name="SpinButtonStates">
                <VisualState x:Name="SpinButtonsCollapsed" />
                <VisualState x:Name="SpinButtonsVisible">
                  <VisualState.Setters>
                    <Setter Target="UpSpinButton.Visibility" Value="Visible" />
                    <Setter Target="DownSpinButton.Visibility" Value="Visible" />
                    <Setter Target="SpinSeparator.Visibility" Value="Visible" />
                    <Setter Target="InputEater.Visibility" Value="Visible" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="SpinButtonsPopup" />
              </VisualStateGroup>
              <VisualStateGroup x:Name="UpSpinButtonEnabledStates">
                <VisualState x:Name="UpSpinButtonEnabled" />
                <VisualState x:Name="UpSpinButtonDisabled">
                  <VisualState.Setters>
                    <Setter Target="UpSpinButton.IsEnabled" Value="False" />
                    <Setter Target="PopupUpSpinButton.IsEnabled" Value="False" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
              <VisualStateGroup x:Name="DownSpinButtonEnabledStates">
                <VisualState x:Name="DownSpinButtonEnabled" />
                <VisualState x:Name="DownSpinButtonDisabled">
                  <VisualState.Setters>
                    <Setter Target="DownSpinButton.IsEnabled" Value="False" />
                    <Setter Target="PopupDownSpinButton.IsEnabled" Value="False" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ContentPresenter x:Name="HeaderContentPresenter"
                              Grid.Row="0" Grid.ColumnSpan="3"
                              Content="{TemplateBinding Header}"
                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                              Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}"
                              FontSize="13"
                              Margin="2,0,0,6"
                              TextWrapping="Wrap"
                              VerticalAlignment="Top"
                              Visibility="Collapsed" />

            <TextBox x:Name="InputBox"
                     Grid.Row="1" Grid.ColumnSpan="3"
                     Style="{StaticResource LiquidGlassNumberBoxInputBoxStyle}"
                     InputScope="{TemplateBinding InputScope}"
                     PlaceholderText="{TemplateBinding PlaceholderText}"
                     SelectionHighlightColor="{TemplateBinding SelectionHighlightColor}"
                     FontSize="{TemplateBinding FontSize}"
                     FontWeight="{TemplateBinding FontWeight}"
                     FontFamily="{TemplateBinding FontFamily}"
                     Background="{TemplateBinding Background}"
                     BorderBrush="{TemplateBinding BorderBrush}"
                     BorderThickness="{TemplateBinding BorderThickness}"
                     Padding="{TemplateBinding Padding}"
                     Foreground="{TemplateBinding Foreground}"
                     TextAlignment="{TemplateBinding TextAlignment}"
                     CornerRadius="{TemplateBinding CornerRadius}"
                     MinHeight="{TemplateBinding MinHeight}" />

            <!-- Compact mode: spin buttons float on the heavier glass surface -->
            <Popup x:Name="UpDownPopup"
                   Grid.Row="1" Grid.Column="1"
                   HorizontalAlignment="Left"
                   ShouldConstrainToRootBounds="False">
              <Border x:Name="PopupContentRoot"
                      Background="{ThemeResource LiquidGlassSurfaceBrush}"
                      BorderBrush="{ThemeResource LiquidGlassStrokeBrush}"
                      BorderThickness="1"
                      CornerRadius="14"
                      Padding="4">
                <StackPanel>
                  <RepeatButton x:Name="PopupUpSpinButton"
                                Style="{StaticResource LiquidGlassSpinButtonStyle}"
                                Width="36" Height="36" Margin="0,0,0,2">
                    <FontIcon Glyph="&#xE70E;" FontSize="14" />
                  </RepeatButton>
                  <RepeatButton x:Name="PopupDownSpinButton"
                                Style="{StaticResource LiquidGlassSpinButtonStyle}"
                                Width="36" Height="36">
                    <FontIcon Glyph="&#xE70D;" FontSize="14" />
                  </RepeatButton>
                </StackPanel>
              </Border>
            </Popup>

            <!-- Eats pointer input between/around the inline spin buttons -->
            <Button x:Name="InputEater"
                    Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                    Visibility="Collapsed"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Margin="3,0,0,0"
                    IsTabStop="False"
                    AutomationProperties.AccessibilityView="Raw">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Grid Background="Transparent" />
                </ControlTemplate>
              </Button.Template>
            </Button>

            <!-- Hairline between the text area and the spinners -->
            <Rectangle x:Name="SpinSeparator"
                       Grid.Row="1" Grid.Column="1"
                       Width="1"
                       Margin="0,10,0,10"
                       HorizontalAlignment="Left"
                       Fill="{ThemeResource LiquidGlassSeparatorBrush}"
                       Opacity="0.6"
                       Visibility="Collapsed"
                       IsHitTestVisible="False" />

            <RepeatButton x:Name="UpSpinButton"
                          Grid.Row="1" Grid.Column="1"
                          Style="{StaticResource LiquidGlassSpinButtonStyle}"
                          Visibility="Collapsed"
                          Margin="3,4,0,4">
              <FontIcon Glyph="&#xE70E;" FontSize="12" />
            </RepeatButton>
            <RepeatButton x:Name="DownSpinButton"
                          Grid.Row="1" Grid.Column="2"
                          Style="{StaticResource LiquidGlassSpinButtonStyle}"
                          Visibility="Collapsed"
                          Margin="0,4,5,4">
              <FontIcon Glyph="&#xE70D;" FontSize="12" />
            </RepeatButton>

            <ContentPresenter x:Name="DescriptionPresenter"
                              Grid.Row="2" Grid.ColumnSpan="3"
                              Content="{TemplateBinding Description}"
                              Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}"
                              FontSize="12"
                              Margin="2,6,0,0"
                              AutomationProperties.AccessibilityView="Raw" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================ RatingControl ============================ -->

  <!-- Glass stars: set/pointer-over stars take the tint, unset stars are the
       tertiary label color (via the RatingControl* keys above). Stock structure
       kept: CaptionStackPanel, RatingBackgroundStackPanel, Caption,
       ForegroundContentPresenter, RatingForegroundStackPanel and both
       TranslateTransforms, plus all CommonStates state names. -->
  <Style x:Key="LiquidGlassRatingControlStyle" TargetType="RatingControl">
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
    <Setter Property="FontFamily" Value="{ThemeResource SymbolThemeFontFamily}" />
    <Setter Property="FocusVisualMargin" Value="-8,-7,-8,0" />
    <Setter Property="IsFocusEngagementEnabled" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RatingControl">
          <Grid x:Name="LayoutRoot" Background="{TemplateBinding Background}">
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Disabled">
                  <VisualState.Setters>
                    <Setter Target="ForegroundContentPresenter.Foreground" Value="{ThemeResource LiquidGlassTertiaryLabelBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Placeholder">
                  <VisualState.Setters>
                    <Setter Target="ForegroundContentPresenter.Foreground" Value="{ThemeResource LiquidGlassTintBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="PointerOverPlaceholder">
                  <VisualState.Setters>
                    <Setter Target="ForegroundContentPresenter.Foreground" Value="{ThemeResource LiquidGlassTintPressedBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="PointerOverUnselected">
                  <VisualState.Setters>
                    <Setter Target="ForegroundContentPresenter.Foreground" Value="{ThemeResource LiquidGlassTintPressedBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Set">
                  <VisualState.Setters>
                    <Setter Target="ForegroundContentPresenter.Foreground" Value="{ThemeResource LiquidGlassTintBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="PointerOverSet">
                  <VisualState.Setters>
                    <Setter Target="ForegroundContentPresenter.Foreground" Value="{ThemeResource LiquidGlassTintPressedBrush}" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <!-- Negative outer margins give the code-driven star scale animations
                 room to render without clipping (as in the stock template) -->
            <StackPanel x:Name="CaptionStackPanel" Orientation="Horizontal" Margin="-20,-20,-20,-20">
              <StackPanel x:Name="RatingBackgroundStackPanel"
                          Orientation="Horizontal"
                          Background="Transparent"
                          Margin="20,20,0,20">
                <StackPanel.RenderTransform>
                  <TranslateTransform x:Name="RatingBackgroundStackPanelTranslateTransform" />
                </StackPanel.RenderTransform>
              </StackPanel>
              <TextBlock x:Name="Caption"
                         Margin="4,0,20,0"
                         TextLineBounds="Tight"
                         FontSize="12"
                         FontFamily="{StaticResource LiquidGlassFontFamily}"
                         Foreground="{TemplateBinding Foreground}"
                         VerticalAlignment="Center"
                         IsHitTestVisible="False"
                         AutomationProperties.AccessibilityView="Raw"
                         AutomationProperties.Name="RatingCaption"
                         Text="{TemplateBinding Caption}" />
            </StackPanel>
            <ContentPresenter x:Name="ForegroundContentPresenter"
                              Foreground="{ThemeResource LiquidGlassTintBrush}"
                              IsHitTestVisible="False">
              <StackPanel Orientation="Horizontal" Margin="-40,-40,-40,-40">
                <StackPanel x:Name="RatingForegroundStackPanel"
                            Orientation="Horizontal"
                            IsHitTestVisible="False"
                            Margin="40,40,40,40">
                  <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="RatingForegroundStackPanelTranslateTransform" />
                  </StackPanel.RenderTransform>
                </StackPanel>
              </StackPanel>
            </ContentPresenter>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- =============================== InfoBar =============================== -->

  <!-- Chromeless close button (&#xE711;) with a soft rounded hover fill -->
  <Style x:Key="LiquidGlassInfoBarCloseButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Width" Value="30" />
    <Setter Property="Height" Value="30" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="PointerOver">
                  <VisualState.Setters>
                    <Setter Target="HoverFill.Opacity" Value="1" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Pressed">
                  <VisualState.Setters>
                    <Setter Target="PressedFill.Opacity" Value="1" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Disabled">
                  <VisualState.Setters>
                    <Setter Target="RootGrid.Opacity" Value="0.3" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Border x:Name="HoverFill"
                    Background="{ThemeResource LiquidGlassHoverOverlayBrush}"
                    CornerRadius="8"
                    Opacity="0" />
            <Border x:Name="PressedFill"
                    Background="{ThemeResource LiquidGlassPressedOverlayBrush}"
                    CornerRadius="8"
                    Opacity="0" />
            <ContentPresenter x:Name="ContentPresenter"
                              Content="{TemplateBinding Content}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              AutomationProperties.AccessibilityView="Raw" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- InfoBar: a glass card for every severity — severity is expressed only by
       the icon glyph + color, never by recoloring the card. Parts kept:
       ContentRoot, StandardIconArea, IconBackground (unused but present),
       StandardIcon, UserIconBox, Title, Message, CloseButton. State groups kept:
       SeverityLevels, IconStates, CloseButton group, InfoBarVisibility,
       Foreground group. -->
  <Style x:Key="LiquidGlassInfoBarStyle" TargetType="InfoBar">
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="CloseButtonStyle" Value="{StaticResource LiquidGlassInfoBarCloseButtonStyle}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="InfoBar">
          <Border x:Name="ContentRoot"
                  VerticalAlignment="Top"
                  Background="{ThemeResource LiquidGlassFillBrush}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}">
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="SeverityLevels">
                <VisualState x:Name="Informational" />
                <VisualState x:Name="Error">
                  <VisualState.Setters>
                    <Setter Target="StandardIcon.Text" Value="&#xEA39;" />
                    <Setter Target="StandardIcon.Foreground" Value="{ThemeResource LiquidGlassDestructiveBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Warning">
                  <VisualState.Setters>
                    <Setter Target="StandardIcon.Text" Value="&#xE7BA;" />
                    <Setter Target="StandardIcon.Foreground" Value="{ThemeResource LiquidGlassWarningBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Success">
                  <VisualState.Setters>
                    <Setter Target="StandardIcon.Text" Value="&#xE930;" />
                    <Setter Target="StandardIcon.Foreground" Value="{ThemeResource LiquidGlassSuccessBrush}" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
              <VisualStateGroup x:Name="IconStates">
                <VisualState x:Name="StandardIconVisible">
                  <VisualState.Setters>
                    <Setter Target="UserIconBox.Visibility" Value="Collapsed" />
                    <Setter Target="StandardIconArea.Visibility" Value="Visible" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="UserIconVisible">
                  <VisualState.Setters>
                    <Setter Target="UserIconBox.Visibility" Value="Visible" />
                    <Setter Target="StandardIconArea.Visibility" Value="Collapsed" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="NoIconVisible" />
              </VisualStateGroup>
              <VisualStateGroup>
                <VisualState x:Name="CloseButtonVisible" />
                <VisualState x:Name="CloseButtonCollapsed">
                  <VisualState.Setters>
                    <Setter Target="CloseButton.Visibility" Value="Collapsed" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
              <VisualStateGroup x:Name="InfoBarVisibility">
                <VisualState x:Name="InfoBarVisible" />
                <VisualState x:Name="InfoBarCollapsed">
                  <VisualState.Setters>
                    <Setter Target="ContentRoot.Visibility" Value="Collapsed" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
              <VisualStateGroup>
                <VisualState x:Name="ForegroundNotSet" />
                <VisualState x:Name="ForegroundSet">
                  <VisualState.Setters>
                    <Setter Target="Title.Foreground" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Foreground}" />
                    <Setter Target="Message.Foreground" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Foreground}" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <!-- Background overrides the glass fill only when explicitly set -->
            <Grid HorizontalAlignment="Stretch"
                  MinHeight="48"
                  Background="{TemplateBinding Background}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Padding="16,12,10,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <Grid x:Name="StandardIconArea" Visibility="Collapsed">
                <!-- The stock two-layer icon backplate is not used; the name is
                     kept for template compatibility -->
                <TextBlock x:Name="IconBackground" Visibility="Collapsed" />
                <TextBlock x:Name="StandardIcon"
                           VerticalAlignment="Top"
                           Margin="0,3,12,0"
                           FontSize="16"
                           Text="&#xE946;"
                           Foreground="{ThemeResource LiquidGlassTintBrush}"
                           FontFamily="{ThemeResource SymbolThemeFontFamily}"
                           AutomationProperties.AccessibilityView="Raw" />
              </Grid>
              <Viewbox x:Name="UserIconBox"
                       Grid.Column="0"
                       Visibility="Collapsed"
                       VerticalAlignment="Top"
                       MaxWidth="16" MaxHeight="16"
                       Margin="0,4,12,0"
                       Child="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.IconElement}" />

              <primitives:InfoBarPanel Grid.Column="1"
                                       Margin="0,1,0,0"
                                       HorizontalOrientationPadding="0"
                                       VerticalOrientationPadding="0">
                <TextBlock x:Name="Title"
                           Text="{TemplateBinding Title}"
                           Foreground="{ThemeResource LiquidGlassLabelBrush}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           TextWrapping="WrapWholeWords"
                           primitives:InfoBarPanel.HorizontalOrientationMargin="0,0,0,0"
                           primitives:InfoBarPanel.VerticalOrientationMargin="0,0,0,0" />
                <TextBlock x:Name="Message"
                           Text="{TemplateBinding Message}"
                           Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}"
                           FontSize="13"
                           TextWrapping="WrapWholeWords"
                           primitives:InfoBarPanel.HorizontalOrientationMargin="12,1,0,0"
                           primitives:InfoBarPanel.VerticalOrientationMargin="0,4,0,0" />
                <ContentPresenter Content="{TemplateBinding ActionButton}"
                                  VerticalAlignment="Top"
                                  primitives:InfoBarPanel.HorizontalOrientationMargin="16,-5,0,0"
                                  primitives:InfoBarPanel.VerticalOrientationMargin="0,10,0,0" />
              </primitives:InfoBarPanel>

              <ContentPresenter Grid.Column="1" Grid.Row="1"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />

              <Button x:Name="CloseButton"
                      Grid.Column="2"
                      Margin="8,-2,0,0"
                      Command="{TemplateBinding CloseButtonCommand}"
                      CommandParameter="{TemplateBinding CloseButtonCommandParameter}"
                      Style="{TemplateBinding CloseButtonStyle}">
                <FontIcon Glyph="&#xE711;" FontSize="11" />
              </Button>
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- =============================== ToolTip =============================== -->

  <!-- Small glass surface floating above the content layer -->
  <Style x:Key="LiquidGlassToolTipStyle" TargetType="ToolTip">
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassLabelBrush}" />
    <Setter Property="Background" Value="{ThemeResource LiquidGlassSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="10,6,10,7" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="MaxWidth" Value="320" />
    <Setter Property="BackgroundSizing" Value="InnerBorderEdge" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToolTip">
          <ContentPresenter x:Name="LayoutRoot"
                            Background="{TemplateBinding Background}"
                            BackgroundSizing="{TemplateBinding BackgroundSizing}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            MaxWidth="{TemplateBinding MaxWidth}"
                            Padding="{TemplateBinding Padding}"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            ContentTransitions="{TemplateBinding ContentTransitions}"
                            TextWrapping="Wrap">
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="OpenStates">
                <VisualState x:Name="Closed">
                  <Storyboard>
                    <FadeOutThemeAnimation TargetName="LayoutRoot" />
                  </Storyboard>
                </VisualState>
                <VisualState x:Name="Opened">
                  <Storyboard>
                    <FadeInThemeAnimation TargetName="LayoutRoot" />
                  </Storyboard>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
          </ContentPresenter>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================== InfoBadge ============================== -->

  <!-- Property-setter style only: the stock template already draws a capsule.
       Severity variants are expressed by setting Background per instance. -->
  <Style x:Key="LiquidGlassInfoBadgeStyle" TargetType="InfoBadge">
    <Setter Property="Background" Value="{ThemeResource LiquidGlassTintBrush}" />
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassOnTintBrush}" />
  </Style>

  <!-- ============================ PersonPicture ============================ -->

  <!-- Initials on a glass circle with a specular hairline. Parts kept: RootGrid,
       InitialsTextBlock, PersonPictureEllipse, BadgeGrid,
       BadgingBackgroundEllipse, BadgingEllipse (+BadgeImageBrush),
       BadgeNumberTextBlock, BadgeGlyphIcon; CommonStates and BadgeStates names
       kept from stock. -->
  <Style x:Key="LiquidGlassPersonPictureStyle" TargetType="PersonPicture">
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassLabelBrush}" />
    <Setter Property="Background" Value="{ThemeResource LiquidGlassControlFillBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Width" Value="96" />
    <Setter Property="Height" Value="96" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="AutomationProperties.AccessibilityView" Value="Raw" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="PersonPicture">
          <Grid x:Name="RootGrid">
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Photo">
                  <VisualState.Setters>
                    <Setter Target="PersonPictureEllipse.Fill" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.ActualImageBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Initials" />
                <VisualState x:Name="NoPhotoOrInitials">
                  <VisualState.Setters>
                    <Setter Target="InitialsTextBlock.FontFamily" Value="{ThemeResource SymbolThemeFontFamily}" />
                    <Setter Target="InitialsTextBlock.Text" Value="&#xE77B;" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Group">
                  <VisualState.Setters>
                    <Setter Target="InitialsTextBlock.FontFamily" Value="{ThemeResource SymbolThemeFontFamily}" />
                    <Setter Target="InitialsTextBlock.Text" Value="&#xE716;" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
              <VisualStateGroup x:Name="BadgeStates">
                <VisualState x:Name="NoBadge" />
                <VisualState x:Name="BadgeWithoutImageSource">
                  <VisualState.Setters>
                    <Setter Target="BadgeGrid.Visibility" Value="Visible" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="BadgeWithImageSource">
                  <VisualState.Setters>
                    <Setter Target="BadgeGrid.Visibility" Value="Visible" />
                    <Setter Target="BadgingEllipse.Opacity" Value="1" />
                    <Setter Target="BadgingEllipse.Fill">
                      <Setter.Value>
                        <ImageBrush x:Name="BadgeImageBrush" Stretch="UniformToFill" />
                      </Setter.Value>
                    </Setter>
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Ellipse Fill="{TemplateBinding Background}"
                     Stroke="{TemplateBinding BorderBrush}"
                     StrokeThickness="{TemplateBinding BorderThickness}"
                     Width="{TemplateBinding Width}"
                     Height="{TemplateBinding Height}" />
            <TextBlock x:Name="InitialsTextBlock"
                       FontSize="40"
                       FontFamily="{TemplateBinding FontFamily}"
                       Foreground="{TemplateBinding Foreground}"
                       FontWeight="{TemplateBinding FontWeight}"
                       TextLineBounds="Tight"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       IsTextScaleFactorEnabled="False"
                       AutomationProperties.AccessibilityView="Raw"
                       Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.ActualInitials}" />
            <Ellipse x:Name="PersonPictureEllipse"
                     Width="{TemplateBinding Width}"
                     Height="{TemplateBinding Height}"
                     FlowDirection="LeftToRight" />
            <Grid x:Name="BadgeGrid"
                  Visibility="Collapsed"
                  VerticalAlignment="Top"
                  HorizontalAlignment="Right">
              <Ellipse x:Name="BadgingBackgroundEllipse"
                       Fill="{ThemeResource LiquidGlassTintBrush}"
                       Stroke="{ThemeResource LiquidGlassOnTintBrush}"
                       StrokeThickness="2" />
              <Ellipse x:Name="BadgingEllipse"
                       Opacity="0"
                       FlowDirection="LeftToRight" />
              <TextBlock x:Name="BadgeNumberTextBlock"
                         Foreground="{ThemeResource LiquidGlassOnTintBrush}"
                         FontFamily="{TemplateBinding FontFamily}"
                         FontWeight="{TemplateBinding FontWeight}"
                         TextLineBounds="Tight"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"
                         IsTextScaleFactorEnabled="False"
                         AutomationProperties.AccessibilityView="Raw" />
              <FontIcon x:Name="BadgeGlyphIcon"
                        Foreground="{ThemeResource LiquidGlassOnTintBrush}"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontWeight="{TemplateBinding FontWeight}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        AutomationProperties.AccessibilityView="Raw" />
            </Grid>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ======================= Implicit registrations ======================== -->
  <!-- (After the definitions so the StaticResource references resolve lexically) -->

</ResourceDictionary>
