<!--
  LiquidGlass.Uno — Controls.xaml
  Styles for controls that keep their stock WinUI templates. Their glass appearance
  comes from the lightweight styling resources overridden in Colors.xaml; these styles
  adjust shape and metrics to Liquid Glass conventions.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- TextBox / PasswordBox live in TextBox.xaml; ToggleSwitch in ToggleSwitch.xaml;
       RadioButton / Slider in Selection.xaml; DatePicker / TimePicker in Pickers.xaml;
       AutoSuggestBox in AutoSuggestBox.xaml -->

  <!-- CheckBox: keep the glyph box a rounded square, not a circle -->
  <Style x:Key="LiquidGlassCheckBoxStyle" TargetType="CheckBox">
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="MinHeight" Value="36" />
  </Style>

  <!-- RadioButton / Slider live in Selection.xaml -->

  <!-- ComboBox: full custom template. The stock template's dropdown resolves
       ComboBoxDropDownBackground / OverlayCornerRadius in framework scope, so
       lightweight overrides never reach it — the popup must be retemplated to
       get the glass surface. Canonical part names (Popup, PopupBorder,
       ContentPresenter, PlaceholderTextBlock, ScrollViewer, HeaderContentPresenter)
       are kept so the control code keeps working; states use opacity overlays,
       never brush-swap keyframes (they mis-resolve on runtime theme switches). -->
  <Style x:Key="LiquidGlassComboBoxStyle" TargetType="ComboBox">
    <Setter Property="Background" Value="{ThemeResource LiquidGlassControlFillBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassLabelBrush}" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Padding" Value="14,9,14,10" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBox">
          <Grid>
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="PointerOver">
                  <VisualState.Setters>
                    <Setter Target="HoverOverlay.Opacity" Value="1" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Pressed">
                  <VisualState.Setters>
                    <Setter Target="PressedOverlay.Opacity" Value="1" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Disabled">
                  <VisualState.Setters>
                    <Setter Target="Background.Opacity" Value="0.4" />
                    <Setter Target="ContentPresenter.Opacity" Value="0.4" />
                    <Setter Target="DropDownGlyph.Opacity" Value="0.4" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
              <VisualStateGroup x:Name="DropDownStates">
                <VisualState x:Name="Opened">
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PopupBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.15" />
                  </Storyboard>
                </VisualState>
                <VisualState x:Name="Closed" />
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="38" />
            </Grid.ColumnDefinitions>

            <ContentPresenter x:Name="HeaderContentPresenter"
                              Grid.Row="0" Grid.ColumnSpan="2"
                              Content="{TemplateBinding Header}"
                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                              Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}"
                              FontSize="13"
                              Margin="0,0,0,6"
                              TextWrapping="Wrap"
                              VerticalAlignment="Top"
                              Visibility="Collapsed"
                              x:DeferLoadStrategy="Lazy" />

            <Border x:Name="Background"
                    Grid.Row="1" Grid.ColumnSpan="2"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Control.IsTemplateFocusTarget="True" />
            <Border x:Name="HoverOverlay"
                    Grid.Row="1" Grid.ColumnSpan="2"
                    Background="{ThemeResource LiquidGlassHoverOverlayBrush}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Opacity="0" />
            <Border x:Name="PressedOverlay"
                    Grid.Row="1" Grid.ColumnSpan="2"
                    Background="{ThemeResource LiquidGlassPressedOverlayBrush}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Opacity="0" />

            <ContentPresenter x:Name="ContentPresenter"
                              Grid.Row="1" Grid.Column="0"
                              Margin="{TemplateBinding Padding}"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
              <TextBlock x:Name="PlaceholderTextBlock"
                         Text="{TemplateBinding PlaceholderText}"
                         Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
            </ContentPresenter>

            <FontIcon x:Name="DropDownGlyph"
                      Grid.Row="1" Grid.Column="1"
                      Glyph="&#xE70D;"
                      FontSize="12"
                      Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}"
                      Margin="0,0,14,0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      IsHitTestVisible="False" />

            <Popup x:Name="Popup">
              <Border x:Name="PopupBorder"
                      Background="{ThemeResource LiquidGlassSurfaceBrush}"
                      BorderBrush="{ThemeResource LiquidGlassStrokeBrush}"
                      BorderThickness="1"
                      CornerRadius="16"
                      Padding="4,6"
                      HorizontalAlignment="Stretch">
                <ScrollViewer x:Name="ScrollViewer"
                              MinWidth="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.DropDownContentMinWidth}"
                              ZoomMode="Disabled"
                              AutomationProperties.AccessibilityView="Raw">
                  <ItemsPresenter />
                </ScrollViewer>
              </Border>
            </Popup>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ComboBoxItem: rounded glass rows inside the dropdown; selection uses the
       persistent highlight band, hover/press are opacity overlays. -->
  <Style x:Key="LiquidGlassComboBoxItemStyle" TargetType="ComboBoxItem">
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassLabelBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="Margin" Value="2,1" />
    <Setter Property="MinHeight" Value="34" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBoxItem">
          <Grid x:Name="LayoutRoot"
                Background="{TemplateBinding Background}"
                CornerRadius="{TemplateBinding CornerRadius}">
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="PointerOver">
                  <VisualState.Setters>
                    <Setter Target="HoverFill.Opacity" Value="1" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Pressed">
                  <VisualState.Setters>
                    <Setter Target="HoverFill.Opacity" Value="1" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Disabled">
                  <VisualState.Setters>
                    <Setter Target="LayoutRoot.Opacity" Value="0.4" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Selected">
                  <VisualState.Setters>
                    <Setter Target="SelectionFill.Opacity" Value="1" />
                    <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource LiquidGlassOnTintBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="SelectedUnfocused">
                  <VisualState.Setters>
                    <Setter Target="SelectionFill.Opacity" Value="1" />
                    <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource LiquidGlassOnTintBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="SelectedDisabled">
                  <VisualState.Setters>
                    <Setter Target="SelectionFill.Opacity" Value="1" />
                    <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource LiquidGlassOnTintBrush}" />
                    <Setter Target="LayoutRoot.Opacity" Value="0.4" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="SelectedPointerOver">
                  <VisualState.Setters>
                    <Setter Target="SelectionFill.Opacity" Value="1" />
                    <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource LiquidGlassOnTintBrush}" />
                    <Setter Target="HoverFill.Opacity" Value="1" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="SelectedPressed">
                  <VisualState.Setters>
                    <Setter Target="SelectionFill.Opacity" Value="1" />
                    <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource LiquidGlassOnTintBrush}" />
                    <Setter Target="HoverFill.Opacity" Value="1" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Border x:Name="SelectionFill"
                    Background="{ThemeResource LiquidGlassTintBrush}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Opacity="0" />
            <Border x:Name="HoverFill"
                    Background="{ThemeResource LiquidGlassHoverOverlayBrush}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Opacity="0" />
            <ContentPresenter x:Name="ContentPresenter"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              ContentTransitions="{TemplateBinding ContentTransitions}"
                              Foreground="{TemplateBinding Foreground}"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              Margin="{TemplateBinding Padding}" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="LiquidGlassProgressBarStyle" TargetType="ProgressBar">
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="MinHeight" Value="6" />
  </Style>

  <Style x:Key="LiquidGlassCalendarDatePickerStyle" TargetType="CalendarDatePicker">
    <Setter Property="Background" Value="{ThemeResource LiquidGlassControlFillBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassLabelBrush}" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="FontSize" Value="15" />
  </Style>

  <!-- Glass card: a Liquid Glass container for grouping content.
       Use with Border via Style, or bind the brushes directly. -->
  <Style x:Key="LiquidGlassCardBorderStyle" TargetType="Border">
    <Setter Property="Background" Value="{ThemeResource LiquidGlassFillBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="26" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <!-- Heavier surface card for panes/sheets -->
  <Style x:Key="LiquidGlassSurfaceBorderStyle" TargetType="Border">
    <Setter Property="Background" Value="{ThemeResource LiquidGlassSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="26" />
    <Setter Property="Padding" Value="16" />
  </Style>
</ResourceDictionary>
