<!--
  LiquidGlass.Uno — ToggleSwitch.xaml
  Apple-style switch: 51x31 capsule track, white round knob, system green when on.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style x:Key="LiquidGlassToggleSwitchStyle" TargetType="ToggleSwitch">
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassLabelBrush}" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleSwitch">
          <Grid x:Name="RootGrid" Background="Transparent">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="PointerOver" />
                <VisualState x:Name="Pressed" />
                <VisualState x:Name="Disabled">
                  <VisualState.Setters>
                    <Setter Target="RootGrid.Opacity" Value="0.45" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
              <VisualStateGroup x:Name="ToggleStates">
                <VisualState x:Name="Dragging" />
                <VisualState x:Name="Off" />
                <VisualState x:Name="On">
                  <VisualState.Setters>
                    <Setter Target="OnTrack.Opacity" Value="1" />
                    <Setter Target="SwitchKnob.HorizontalAlignment" Value="Right" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
              <VisualStateGroup x:Name="ContentStates">
                <VisualState x:Name="OffContent">
                  <VisualState.Setters>
                    <Setter Target="OffContentPresenter.Visibility" Value="Visible" />
                    <Setter Target="OnContentPresenter.Visibility" Value="Collapsed" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="OnContent">
                  <VisualState.Setters>
                    <Setter Target="OffContentPresenter.Visibility" Value="Collapsed" />
                    <Setter Target="OnContentPresenter.Visibility" Value="Visible" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <ContentPresenter x:Name="HeaderContentPresenter"
                              Grid.Row="0"
                              Content="{TemplateBinding Header}"
                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                              Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}"
                              FontSize="13"
                              Margin="2,0,0,6"
                              Visibility="Collapsed" />

            <Grid x:Name="SwitchAreaGrid" Grid.Row="1" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Center">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <Grid Width="51" Height="31" VerticalAlignment="Center">
                <!-- Off track: frosted gray -->
                <Border x:Name="OffTrack"
                        Background="{ThemeResource ToggleSwitchFillOff}"
                        CornerRadius="15.5" />
                <!-- On track: Apple system green -->
                <Border x:Name="OnTrack"
                        Background="{ThemeResource LiquidGlassSuccessBrush}"
                        CornerRadius="15.5"
                        Opacity="0" />
                <!-- Specular kiss on the track -->
                <Border Background="{ThemeResource LiquidGlassSpecularBrush}"
                        CornerRadius="15.5"
                        IsHitTestVisible="False" />
                <!-- Knob -->
                <Ellipse x:Name="SwitchKnob"
                         Width="27" Height="27"
                         Fill="#FFFFFF"
                         Stroke="#14000000"
                         StrokeThickness="0.5"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         Margin="2,0" />
              </Grid>

              <ContentPresenter x:Name="OffContentPresenter"
                                Grid.Column="1"
                                Content="{TemplateBinding OffContent}"
                                ContentTemplate="{TemplateBinding OffContentTemplate}"
                                Foreground="{TemplateBinding Foreground}"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0" />
              <ContentPresenter x:Name="OnContentPresenter"
                                Grid.Column="1"
                                Content="{TemplateBinding OnContent}"
                                ContentTemplate="{TemplateBinding OnContentTemplate}"
                                Foreground="{TemplateBinding Foreground}"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0"
                                Visibility="Collapsed" />

              <!-- REQUIRED interaction part: Uno's ToggleSwitch attaches its
                   tap and drag handlers to the "SwitchThumb" Thumb — without it
                   the control renders but never toggles on click. -->
              <Thumb x:Name="SwitchThumb" Grid.ColumnSpan="2" AutomationProperties.AccessibilityView="Raw">
                <Thumb.Template>
                  <ControlTemplate TargetType="Thumb">
                    <Rectangle Fill="Transparent" />
                  </ControlTemplate>
                </Thumb.Template>
              </Thumb>
            </Grid>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
