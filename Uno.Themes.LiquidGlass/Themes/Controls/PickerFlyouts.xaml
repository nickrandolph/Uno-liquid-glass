<!--
  LiquidGlass.Uno — PickerFlyouts.xaml
  DatePickerFlyoutPresenter / TimePickerFlyoutPresenter on the heavier glass surface.
  Templates replicate the part names the presenters resolve at runtime (Background,
  ContentPanel, PickerHostGrid / *PickerHost borders, *Column definitions, picker
  spacings, HighlightRect, AcceptDismissHostGrid, Accept/Dismiss buttons) so the
  looping selectors keep being injected and driven by the controls.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Accept / dismiss commands at the bottom of the picker surface -->
  <Style x:Key="LiquidGlassPickerFlyoutCommandButtonStyle" TargetType="ButtonBase">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassLabelBrush}" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="UseSystemFocusVisuals" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ButtonBase">
          <Grid x:Name="RootGrid" Margin="2">
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="PointerOver">
                  <VisualState.Setters>
                    <Setter Target="HoverOverlay.Opacity" Value="1" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Pressed">
                  <VisualState.Setters>
                    <Setter Target="PressOverlay.Opacity" Value="1" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Disabled">
                  <VisualState.Setters>
                    <Setter Target="RootGrid.Opacity" Value="0.45" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Border x:Name="HoverOverlay"
                    Background="{ThemeResource LiquidGlassHighlightBrush}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Opacity="0" />
            <Border x:Name="PressOverlay"
                    Background="{ThemeResource LiquidGlassPressedOverlayBrush}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Opacity="0" />
            <ContentPresenter Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              AutomationProperties.AccessibilityView="Raw" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ==================== DatePickerFlyoutPresenter ==================== -->
  <Style x:Key="LiquidGlassDatePickerFlyoutPresenterStyle" TargetType="DatePickerFlyoutPresenter">
    <Setter Property="Width" Value="296" />
    <Setter Property="MinWidth" Value="296" />
    <Setter Property="MaxHeight" Value="398" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Background" Value="{ThemeResource LiquidGlassSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="26" />
    <Setter Property="AutomationProperties.AutomationId" Value="DatePickerFlyoutPresenter" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="DatePickerFlyoutPresenter">
          <Border x:Name="Background"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Padding="6"
                  MaxHeight="398">
            <Grid x:Name="ContentPanel">
              <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <Grid x:Name="PickerHostGrid">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="78*" x:Name="DayColumn" />
                  <ColumnDefinition Width="Auto" x:Name="FirstSpacerColumn" />
                  <ColumnDefinition Width="132*" x:Name="MonthColumn" />
                  <ColumnDefinition Width="Auto" x:Name="SecondSpacerColumn" />
                  <ColumnDefinition Width="78*" x:Name="YearColumn" />
                </Grid.ColumnDefinitions>

                <!-- Selection band behind the focused row -->
                <Border x:Name="HighlightRect"
                        Background="{ThemeResource LiquidGlassHighlightBrush}"
                        CornerRadius="10"
                        Grid.Column="0"
                        Grid.ColumnSpan="5"
                        VerticalAlignment="Center"
                        Margin="4,0"
                        Height="40" />
                <Rectangle x:Name="FirstPickerSpacing"
                           Fill="Transparent"
                           HorizontalAlignment="Center"
                           Width="2"
                           Grid.Column="1" />
                <Rectangle x:Name="SecondPickerSpacing"
                           Fill="Transparent"
                           HorizontalAlignment="Center"
                           Width="2"
                           Grid.Column="3" />
              </Grid>

              <Grid Grid.Row="1" Height="41" x:Name="AcceptDismissHostGrid">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Rectangle Height="1"
                           VerticalAlignment="Top"
                           Fill="{ThemeResource LiquidGlassSeparatorBrush}"
                           Margin="8,0"
                           Grid.ColumnSpan="2" />
                <Button x:Name="AcceptButton"
                        Grid.Column="0"
                        Content="&#xE8FB;"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="16"
                        Foreground="{ThemeResource LiquidGlassTintBrush}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource LiquidGlassPickerFlyoutCommandButtonStyle}" />
                <Button x:Name="DismissButton"
                        Grid.Column="1"
                        Content="&#xE711;"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="16"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource LiquidGlassPickerFlyoutCommandButtonStyle}" />
              </Grid>
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ==================== TimePickerFlyoutPresenter ==================== -->
  <Style x:Key="LiquidGlassTimePickerFlyoutPresenterStyle" TargetType="TimePickerFlyoutPresenter">
    <Setter Property="Width" Value="242" />
    <Setter Property="MinWidth" Value="242" />
    <Setter Property="MaxHeight" Value="398" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Background" Value="{ThemeResource LiquidGlassSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="26" />
    <Setter Property="AutomationProperties.AutomationId" Value="TimePickerFlyoutPresenter" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TimePickerFlyoutPresenter">
          <Border x:Name="Background"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Padding="6"
                  MaxHeight="398">
            <Grid x:Name="ContentPanel">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock x:Name="TitlePresenter"
                         Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}"
                         FontSize="13"
                         Margin="12,6,12,4"
                         Visibility="Collapsed"
                         AutomationProperties.AccessibilityView="Raw" />

              <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" x:Name="FirstPickerHostColumn" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" x:Name="SecondPickerHostColumn" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" x:Name="ThirdPickerHostColumn" />
                </Grid.ColumnDefinitions>

                <Border x:Name="HighlightRect"
                        Background="{ThemeResource LiquidGlassHighlightBrush}"
                        CornerRadius="10"
                        Grid.Column="0"
                        Grid.ColumnSpan="5"
                        VerticalAlignment="Center"
                        Margin="4,0"
                        Height="40" />
                <Border x:Name="FirstPickerHost" Grid.Column="0" />
                <Rectangle x:Name="FirstPickerSpacing"
                           Fill="Transparent"
                           HorizontalAlignment="Center"
                           Width="2"
                           Grid.Column="1" />
                <Border x:Name="SecondPickerHost" Grid.Column="2" />
                <Rectangle x:Name="SecondPickerSpacing"
                           Fill="Transparent"
                           HorizontalAlignment="Center"
                           Width="2"
                           Grid.Column="3" />
                <Border x:Name="ThirdPickerHost" Grid.Column="4" />
              </Grid>

              <Grid Grid.Row="2" Height="41" x:Name="AcceptDismissHostGrid">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Rectangle Height="1"
                           VerticalAlignment="Top"
                           Fill="{ThemeResource LiquidGlassSeparatorBrush}"
                           Margin="8,0"
                           Grid.ColumnSpan="2" />
                <Button x:Name="AcceptButton"
                        Grid.Column="0"
                        Content="&#xE8FB;"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="16"
                        Foreground="{ThemeResource LiquidGlassTintBrush}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource LiquidGlassPickerFlyoutCommandButtonStyle}" />
                <Button x:Name="DismissButton"
                        Grid.Column="1"
                        Content="&#xE711;"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="16"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource LiquidGlassPickerFlyoutCommandButtonStyle}" />
              </Grid>
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
