<Page x:Class="LiquidGlassGallery.Pages.UnoToolkitPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI">
  <ScrollViewer>
    <StackPanel Padding="28" Spacing="22" MaxWidth="900" HorizontalAlignment="Center">
      <StackPanel Spacing="5">
        <TextBlock Text="Uno Toolkit" FontSize="30" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
        <TextBlock Text="Liquid Glass treatments for every visual Uno.Toolkit.WinUI control family."
                   FontSize="15" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
      </StackPanel>

      <utu:NavigationBar Content="Glass navigation">
        <utu:NavigationBar.MainCommand>
          <AppBarButton Icon="Back" Label="Back" />
        </utu:NavigationBar.MainCommand>
        <utu:NavigationBar.PrimaryCommands>
          <AppBarButton Icon="Add" Label="Add" />
          <AppBarButton Icon="More" Label="More" />
        </utu:NavigationBar.PrimaryCommands>
      </utu:NavigationBar>

      <utu:Card HeaderContent="Liquid Glass card"
                SubHeaderContent="Card and CardContentControl"
                SupportingContent="Adaptive translucent fill, specular border, concentric corners, and interaction states come from the shared Liquid Glass tokens."
                IsClickable="True">
        <utu:Card.IconsContent>
          <Button Content="Details" Style="{StaticResource LiquidGlassQueryButtonStyle}" />
        </utu:Card.IconsContent>
      </utu:Card>

      <utu:CardContentControl IsClickable="True">
        <Grid ColumnSpacing="14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Width="48" Height="48" CornerRadius="16" Background="{ThemeResource LiquidGlassProminentFillBrush}">
            <FontIcon Glyph="&#xE8A9;" Foreground="White" />
          </Border>
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock Text="Content card" FontSize="17" FontWeight="SemiBold" />
            <TextBlock Text="Use any custom content without losing the glass interaction states."
                       Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" TextWrapping="Wrap" />
          </StackPanel>
        </Grid>
      </utu:CardContentControl>

      <StackPanel Spacing="10">
        <TextBlock Text="Chips and divider" FontSize="18" FontWeight="SemiBold" />
        <utu:ChipGroup SelectionMode="Multiple">
          <utu:Chip Content="Clear" IsChecked="True" />
          <utu:Chip Content="Regular" />
          <utu:Chip Content="Tinted" IsChecked="True" />
          <utu:Chip Content="Removable" CanRemove="True" />
        </utu:ChipGroup>
        <utu:Divider SubHeader="The separator and secondary label adapt to light and dark appearance." />
      </StackPanel>

      <StackPanel Spacing="10">
        <TextBlock Text="Tab bar" FontSize="18" FontWeight="SemiBold" />
        <utu:TabBar SelectedIndex="0">
          <utu:TabBar.Items>
            <utu:TabBarItem Content="Home"><utu:TabBarItem.Icon><SymbolIcon Symbol="Home" /></utu:TabBarItem.Icon></utu:TabBarItem>
            <utu:TabBarItem Content="Search"><utu:TabBarItem.Icon><SymbolIcon Symbol="Find" /></utu:TabBarItem.Icon></utu:TabBarItem>
            <utu:TabBarItem Content="Saved"><utu:TabBarItem.Icon><SymbolIcon Symbol="Favorite" /></utu:TabBarItem.Icon></utu:TabBarItem>
          </utu:TabBar.Items>
        </utu:TabBar>
      </StackPanel>

      <Grid ColumnSpacing="16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <utu:SafeArea MinHeight="140">
          <StackPanel VerticalAlignment="Center" Spacing="5">
            <TextBlock Text="SafeArea" FontSize="17" FontWeight="SemiBold" />
            <TextBlock Text="Insets and glass content remain composable on mobile and desktop."
                       TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
          </StackPanel>
        </utu:SafeArea>
        <utu:ZoomContentControl Grid.Column="1" Height="140" MinZoomLevel="0.5" MaxZoomLevel="4" ZoomLevel="1">
          <Border Width="120" Height="72" CornerRadius="18" Background="{ThemeResource LiquidGlassProminentFillBrush}">
            <TextBlock Text="Pinch or scroll" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </utu:ZoomContentControl>
      </Grid>

      <utu:ResponsiveView>
        <utu:ResponsiveView.NarrowestTemplate>
          <DataTemplate><TextBlock Text="ResponsiveView: narrow glass layout" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" /></DataTemplate>
        </utu:ResponsiveView.NarrowestTemplate>
        <utu:ResponsiveView.NormalTemplate>
          <DataTemplate><TextBlock Text="ResponsiveView: regular glass layout" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" /></DataTemplate>
        </utu:ResponsiveView.NormalTemplate>
        <utu:ResponsiveView.WideTemplate>
          <DataTemplate><TextBlock Text="ResponsiveView: wide glass layout" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" /></DataTemplate>
        </utu:ResponsiveView.WideTemplate>
      </utu:ResponsiveView>

      <StackPanel Orientation="Horizontal" Spacing="10">
        <Button Content="Open drawer" Click="OnOpenDrawer" />
        <Button Content="Open bottom drawer flyout">
          <Button.Flyout>
            <Flyout Placement="Full" FlyoutPresenterStyle="{StaticResource LiquidGlassBottomDrawerFlyoutPresenterStyle}">
              <StackPanel Padding="24" Spacing="12" MinHeight="180">
                <TextBlock Text="DrawerFlyoutPresenter" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="Gesture-capable drawer surfaces share the heavier Liquid Glass material." />
                <Button Content="Done" HorizontalAlignment="Left" />
              </StackPanel>
            </Flyout>
          </Button.Flyout>
        </Button>
      </StackPanel>

      <utu:LoadingView MinHeight="90">
        <utu:LoadingView.LoadingContent>
          <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
            <ProgressRing IsActive="True" Width="24" Height="24" />
            <TextBlock Text="Loading glass content…" VerticalAlignment="Center" />
          </StackPanel>
        </utu:LoadingView.LoadingContent>
        <TextBlock Text="LoadingView content is ready." HorizontalAlignment="Center" />
      </utu:LoadingView>

      <utu:DrawerControl x:Name="DemoDrawer" Height="220" DrawerDepth="300" OpenDirection="Left">
        <utu:DrawerControl.DrawerContent>
          <StackPanel Spacing="12">
            <TextBlock Text="DrawerControl" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="The drawer uses a frosted surface, specular border, and dimmed backdrop." TextWrapping="Wrap" />
            <Button Content="Close" Click="OnCloseDrawer" HorizontalAlignment="Left" />
          </StackPanel>
        </utu:DrawerControl.DrawerContent>
        <Border Background="{ThemeResource LiquidGlassClearFillBrush}" CornerRadius="26" Padding="24">
          <TextBlock Text="Drawer host content" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
      </utu:DrawerControl>
    </StackPanel>
  </ScrollViewer>
</Page>
