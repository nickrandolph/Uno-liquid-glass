<!--
  LiquidGlass.CommunityToolkit — RangeSelector.xaml
  Lightweight styling overrides for CommunityToolkit.WinUI.Controls.RangeSelector.

  The toolkit's RangeSelector template reuses the WinUI Slider lightweight keys
  (SliderTrackFill, SliderTrackValueFill*, SliderThumbBackground*, SliderOuterThumbBackground,
  SliderThumbBorderBrush, *Disabled) — see RangeSelector.xaml in the toolkit sources.
  Values match the Liquid Glass Slider look defined in LiquidGlass.Uno
  (translucent gray track, tint value band between the thumbs, white round thumbs);
  the base Slider* keys are restated here so the dictionary stands on its own.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ResourceDictionary.ThemeDictionaries>

    <!-- ================================ LIGHT ================================ -->
    <ResourceDictionary x:Key="Light">

      <!-- Out-of-range track: translucent systemGray; in-range band: Apple tint
           (same values as the theme's Slider overrides in Colors.xaml) -->
      <SolidColorBrush x:Key="SliderTrackFill" Color="#3C787880" />
      <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="#52787880" />
      <SolidColorBrush x:Key="SliderTrackFillPressed" Color="#52787880" />
      <SolidColorBrush x:Key="SliderTrackFillDisabled" Color="#29787880" />
      <SolidColorBrush x:Key="SliderTrackValueFill" Color="#007AFF" />
      <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="#3395FF" />
      <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="#0066D6" />
      <SolidColorBrush x:Key="SliderTrackValueFillDisabled" Color="#66007AFF" />

      <!-- Thumbs: solid white knobs (outer ring and inner fill both white) -->
      <SolidColorBrush x:Key="SliderOuterThumbBackground" Color="#FFFFFF" />
      <SolidColorBrush x:Key="SliderThumbBackground" Color="#FFFFFF" />
      <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="#FFFFFF" />
      <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="#F0F0F0" />
      <SolidColorBrush x:Key="SliderThumbBackgroundDisabled" Color="#F0F0F0" />
      <SolidColorBrush x:Key="SliderThumbBorderBrush" Color="#1F000000" />
    </ResourceDictionary>

    <!-- ================================ DARK ================================ -->
    <ResourceDictionary x:Key="Default">

      <SolidColorBrush x:Key="SliderTrackFill" Color="#52787880" />
      <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="#66787880" />
      <SolidColorBrush x:Key="SliderTrackFillPressed" Color="#66787880" />
      <SolidColorBrush x:Key="SliderTrackFillDisabled" Color="#33787880" />
      <SolidColorBrush x:Key="SliderTrackValueFill" Color="#0A84FF" />
      <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="#409CFF" />
      <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="#086CD9" />
      <SolidColorBrush x:Key="SliderTrackValueFillDisabled" Color="#660A84FF" />

      <SolidColorBrush x:Key="SliderOuterThumbBackground" Color="#FFFFFF" />
      <SolidColorBrush x:Key="SliderThumbBackground" Color="#FFFFFF" />
      <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="#FFFFFF" />
      <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="#F0F0F0" />
      <SolidColorBrush x:Key="SliderThumbBackgroundDisabled" Color="#8C8C8C" />
      <SolidColorBrush x:Key="SliderThumbBorderBrush" Color="#1F000000" />
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
