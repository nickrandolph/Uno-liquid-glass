<!--
  LiquidGlass.CommunityToolkit — Sizers (GridSplitter / ContentSizer / PropertySizer / SizerBase)

  The WCT SizerBase template (SizerBase.xaml in CommunityToolkit.WinUI.Controls.Sizers)
  resolves all of its brushes and grip metrics via ThemeResource lookups, so we restyle it
  through lightweight resource overrides only — no template replacement.

  Keys overridden (from the package's SizerBase.xaml):
    SizerBaseBackground / PointerOver / Pressed / Disabled — the splitter track
    SizerBaseForeground                                    — the capsule grip (PART_Thumb fill)
    SizerBaseThumbHeight / Width / Radius, SizerBasePadding — grip metrics

  Glass mapping: grip = LiquidGlassSeparatorBrush on a clear glass track
  (LiquidGlassClearFillBrush), hover = LiquidGlassFillPointerOverBrush,
  pressed = LiquidGlassFillPressedBrush.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Default">
      <StaticResource x:Key="SizerBaseBackground" ResourceKey="LiquidGlassClearFillBrush" />
      <StaticResource x:Key="SizerBaseBackgroundPointerOver" ResourceKey="LiquidGlassFillPointerOverBrush" />
      <StaticResource x:Key="SizerBaseBackgroundPressed" ResourceKey="LiquidGlassFillPressedBrush" />
      <StaticResource x:Key="SizerBaseBackgroundDisabled" ResourceKey="LiquidGlassClearFillBrush" />
      <StaticResource x:Key="SizerBaseForeground" ResourceKey="LiquidGlassSeparatorBrush" />
    </ResourceDictionary>
    <ResourceDictionary x:Key="Light">
      <StaticResource x:Key="SizerBaseBackground" ResourceKey="LiquidGlassClearFillBrush" />
      <StaticResource x:Key="SizerBaseBackgroundPointerOver" ResourceKey="LiquidGlassFillPointerOverBrush" />
      <StaticResource x:Key="SizerBaseBackgroundPressed" ResourceKey="LiquidGlassFillPressedBrush" />
      <StaticResource x:Key="SizerBaseBackgroundDisabled" ResourceKey="LiquidGlassClearFillBrush" />
      <StaticResource x:Key="SizerBaseForeground" ResourceKey="LiquidGlassSeparatorBrush" />
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>

  <!--  Slightly longer, capsule-shaped grip than the Fluent default (24x4, radius 2)  -->
  <x:Double x:Key="SizerBaseThumbHeight">28</x:Double>
  <x:Double x:Key="SizerBaseThumbWidth">4</x:Double>
  <x:Double x:Key="SizerBaseThumbRadius">2</x:Double>
  <Thickness x:Key="SizerBasePadding">4</Thickness>

</ResourceDictionary>
