<!--
  LiquidGlass.CommunityToolkit — Settings.xaml
  Lightweight styling overrides for the Windows Community Toolkit (8.x)
  SettingsCard and SettingsExpander. The toolkit templates resolve every one of
  these keys via {ThemeResource}, so redefining them at app scope re-skins the
  stock templates without replacing them.

  Key map (verified against WCT source, SettingsControls/src):
  - SettingsCard*            → card fill / foreground / rim (SettingsCard.xaml)
  - SettingsExpander header  → reuses SettingsCardBackground* + SettingsCardBorderBrush*
                               plus ExpanderHeaderForeground* / ExpanderChevron*Foreground
  - SettingsExpander content → ExpanderContentBackground / ExpanderContentBorderBrush
    (note: the Expander* keys are the stock WinUI Expander keys, so a plain
    Expander picks up the same clear-glass content area — intentional.)

  Brush values mirror LiquidGlass.Uno/Themes/Colors.xaml
  (LiquidGlassFillBrush, LiquidGlassStrokeBrush, label brushes). They are
  duplicated as concrete values so this dictionary has no merge-order
  dependency on the LiquidGlass.Uno dictionaries.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ResourceDictionary.ThemeDictionaries>

    <!-- ================================ LIGHT ================================ -->
    <ResourceDictionary x:Key="Light">

      <!-- SettingsCard fill: regular liquid glass material -->
      <AcrylicBrush x:Key="SettingsCardBackground"
                    TintColor="#F5F5F7" TintOpacity="0.45"
                    FallbackColor="#B8FFFFFF" />
      <AcrylicBrush x:Key="SettingsCardBackgroundPointerOver"
                    TintColor="#FFFFFF" TintOpacity="0.55"
                    FallbackColor="#CCFFFFFF" />
      <AcrylicBrush x:Key="SettingsCardBackgroundPressed"
                    TintColor="#E5E5EA" TintOpacity="0.6"
                    FallbackColor="#D9E5E5EA" />
      <SolidColorBrush x:Key="SettingsCardBackgroundDisabled" Color="#66F5F5F7" />

      <!-- SettingsCard text: Apple label / secondaryLabel / tertiaryLabel -->
      <SolidColorBrush x:Key="SettingsCardForeground" Color="#000000" />
      <SolidColorBrush x:Key="SettingsCardForegroundPointerOver" Color="#000000" />
      <SolidColorBrush x:Key="SettingsCardForegroundPressed" Color="#993C3C43" />
      <SolidColorBrush x:Key="SettingsCardForegroundDisabled" Color="#4D3C3C43" />

      <!-- SettingsCard rim: specular top edge fading to a faint dark bottom edge -->
      <LinearGradientBrush x:Key="SettingsCardBorderBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#B3FFFFFF" />
        <GradientStop Offset="0.5" Color="#33FFFFFF" />
        <GradientStop Offset="1" Color="#21000000" />
      </LinearGradientBrush>
      <StaticResource x:Key="SettingsCardBorderBrushPointerOver" ResourceKey="SettingsCardBorderBrush" />
      <StaticResource x:Key="SettingsCardBorderBrushPressed" ResourceKey="SettingsCardBorderBrush" />
      <StaticResource x:Key="SettingsCardBorderBrushDisabled" ResourceKey="SettingsCardBorderBrush" />

      <!-- SettingsExpander header text + chevron -->
      <SolidColorBrush x:Key="ExpanderHeaderForeground" Color="#000000" />
      <SolidColorBrush x:Key="ExpanderHeaderForegroundPointerOver" Color="#000000" />
      <SolidColorBrush x:Key="ExpanderHeaderForegroundPressed" Color="#993C3C43" />
      <SolidColorBrush x:Key="ExpanderHeaderDisabledForeground" Color="#4D3C3C43" />
      <StaticResource x:Key="ExpanderHeaderBorderBrush" ResourceKey="SettingsCardBorderBrush" />
      <SolidColorBrush x:Key="ExpanderChevronForeground" Color="#993C3C43" />
      <SolidColorBrush x:Key="ExpanderChevronPointerOverForeground" Color="#993C3C43" />
      <SolidColorBrush x:Key="ExpanderChevronPressedForeground" Color="#993C3C43" />
      <SolidColorBrush x:Key="ExpanderChevronBackground" Color="Transparent" />
      <SolidColorBrush x:Key="ExpanderChevronBorderBrush" Color="Transparent" />

      <!-- SettingsExpander expanded items area: clear glass with a hairline on top -->
      <AcrylicBrush x:Key="ExpanderContentBackground"
                    TintColor="#FFFFFF" TintOpacity="0.15"
                    FallbackColor="#40FFFFFF" />
      <SolidColorBrush x:Key="ExpanderContentBorderBrush" Color="#5C3C3C43" />
    </ResourceDictionary>

    <!-- ================================ DARK ================================ -->
    <ResourceDictionary x:Key="Default">

      <AcrylicBrush x:Key="SettingsCardBackground"
                    TintColor="#1C1C1E" TintOpacity="0.45"
                    FallbackColor="#A63A3A3C" />
      <AcrylicBrush x:Key="SettingsCardBackgroundPointerOver"
                    TintColor="#2C2C2E" TintOpacity="0.55"
                    FallbackColor="#BF48484A" />
      <AcrylicBrush x:Key="SettingsCardBackgroundPressed"
                    TintColor="#0F0F10" TintOpacity="0.6"
                    FallbackColor="#CC2C2C2E" />
      <SolidColorBrush x:Key="SettingsCardBackgroundDisabled" Color="#402C2C2E" />

      <SolidColorBrush x:Key="SettingsCardForeground" Color="#FFFFFF" />
      <SolidColorBrush x:Key="SettingsCardForegroundPointerOver" Color="#FFFFFF" />
      <SolidColorBrush x:Key="SettingsCardForegroundPressed" Color="#99EBEBF5" />
      <SolidColorBrush x:Key="SettingsCardForegroundDisabled" Color="#4DEBEBF5" />

      <LinearGradientBrush x:Key="SettingsCardBorderBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#59FFFFFF" />
        <GradientStop Offset="0.5" Color="#1FFFFFFF" />
        <GradientStop Offset="1" Color="#40000000" />
      </LinearGradientBrush>
      <StaticResource x:Key="SettingsCardBorderBrushPointerOver" ResourceKey="SettingsCardBorderBrush" />
      <StaticResource x:Key="SettingsCardBorderBrushPressed" ResourceKey="SettingsCardBorderBrush" />
      <StaticResource x:Key="SettingsCardBorderBrushDisabled" ResourceKey="SettingsCardBorderBrush" />

      <SolidColorBrush x:Key="ExpanderHeaderForeground" Color="#FFFFFF" />
      <SolidColorBrush x:Key="ExpanderHeaderForegroundPointerOver" Color="#FFFFFF" />
      <SolidColorBrush x:Key="ExpanderHeaderForegroundPressed" Color="#99EBEBF5" />
      <SolidColorBrush x:Key="ExpanderHeaderDisabledForeground" Color="#4DEBEBF5" />
      <StaticResource x:Key="ExpanderHeaderBorderBrush" ResourceKey="SettingsCardBorderBrush" />
      <SolidColorBrush x:Key="ExpanderChevronForeground" Color="#99EBEBF5" />
      <SolidColorBrush x:Key="ExpanderChevronPointerOverForeground" Color="#99EBEBF5" />
      <SolidColorBrush x:Key="ExpanderChevronPressedForeground" Color="#99EBEBF5" />
      <SolidColorBrush x:Key="ExpanderChevronBackground" Color="Transparent" />
      <SolidColorBrush x:Key="ExpanderChevronBorderBrush" Color="Transparent" />

      <AcrylicBrush x:Key="ExpanderContentBackground"
                    TintColor="#000000" TintOpacity="0.15"
                    FallbackColor="#40000000" />
      <SolidColorBrush x:Key="ExpanderContentBorderBrush" Color="#99545458" />
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>

  <!-- Metrics tuned to match the DevWinUI.LiquidGlass settings rows
       (MinHeight 56, Padding 16,12, 13pt descriptions). CornerRadius has no
       dedicated key (the templates use ControlCornerRadius), so the 16px card
       radius is applied per-instance in the gallery pages. -->
  <x:Double x:Key="SettingsCardMinHeight">56</x:Double>
  <Thickness x:Key="SettingsCardPadding">16,12</Thickness>
  <Thickness x:Key="SettingsExpanderHeaderPadding">16,12,4,12</Thickness>
  <x:Double x:Key="SettingsCardDescriptionFontSize">13</x:Double>
</ResourceDictionary>
