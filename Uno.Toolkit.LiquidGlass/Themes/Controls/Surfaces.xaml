<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:utu="using:Uno.Toolkit.UI">

  <Style x:Key="LiquidGlassToolkitDrawerStyle" TargetType="utu:DrawerControl">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="DrawerBackground" Value="{ThemeResource UnoToolkitGlassSurface}" />
    <Setter Property="LightDismissOverlayBackground" Value="{ThemeResource UnoToolkitGlassOverlay}" />
    <Setter Property="FitToDrawerContent" Value="True" />
    <Setter Property="EdgeSwipeDetectionLength" Value="50" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="utu:DrawerControl">
          <Grid x:Name="RootPanel" Background="{TemplateBinding Background}">
            <ContentPresenter x:Name="MainContentPresenter" Content="{TemplateBinding Content}" />
            <Border x:Name="LightDismissOverlay" Background="{TemplateBinding LightDismissOverlayBackground}" />
            <ContentControl x:Name="DrawerContentControl"
                            Content="{TemplateBinding DrawerContent}"
                            Background="{TemplateBinding DrawerBackground}"
                            Padding="18"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch">
              <ContentControl.Template>
                <ControlTemplate TargetType="ContentControl">
                  <Border Background="{TemplateBinding Background}"
                          BorderBrush="{ThemeResource UnoToolkitGlassStroke}"
                          BorderThickness="1"
                          CornerRadius="26">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                  </Border>
                </ControlTemplate>
              </ContentControl.Template>
              <ContentControl.RenderTransform>
                <TranslateTransform />
              </ContentControl.RenderTransform>
            </ContentControl>
            <Border x:Name="GestureInterceptor" Background="Transparent" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="LiquidGlassToolkitDrawerFlyoutPresenterStyle"
         TargetType="utu:DrawerFlyoutPresenter"
         BasedOn="{StaticResource DefaultDrawerFlyoutPresenterStyle}">
    <Setter Property="Background" Value="{ThemeResource UnoToolkitGlassSurface}" />
    <Setter Property="BorderBrush" Value="{ThemeResource UnoToolkitGlassStroke}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="26" />
  </Style>

  <Style x:Key="LiquidGlassDrawerFlyoutPresenterStyle"
         TargetType="FlyoutPresenter"
         BasedOn="{StaticResource DrawerFlyoutPresenterStyle}">
    <Setter Property="Background" Value="{ThemeResource UnoToolkitGlassSurface}" />
    <Setter Property="BorderBrush" Value="{ThemeResource UnoToolkitGlassStroke}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="26" />
    <Setter Property="utu:DrawerFlyoutPresenter.LightDismissOverlayBackground" Value="{ThemeResource UnoToolkitGlassOverlay}" />
  </Style>
  <Style x:Key="LiquidGlassLeftDrawerFlyoutPresenterStyle"
         TargetType="FlyoutPresenter"
         BasedOn="{StaticResource LiquidGlassDrawerFlyoutPresenterStyle}">
    <Setter Property="utu:DrawerFlyoutPresenter.OpenDirection" Value="Right" />
  </Style>
  <Style x:Key="LiquidGlassTopDrawerFlyoutPresenterStyle"
         TargetType="FlyoutPresenter"
         BasedOn="{StaticResource LiquidGlassDrawerFlyoutPresenterStyle}">
    <Setter Property="utu:DrawerFlyoutPresenter.OpenDirection" Value="Down" />
  </Style>
  <Style x:Key="LiquidGlassRightDrawerFlyoutPresenterStyle"
         TargetType="FlyoutPresenter"
         BasedOn="{StaticResource LiquidGlassDrawerFlyoutPresenterStyle}">
    <Setter Property="utu:DrawerFlyoutPresenter.OpenDirection" Value="Left" />
  </Style>
  <Style x:Key="LiquidGlassBottomDrawerFlyoutPresenterStyle"
         TargetType="FlyoutPresenter"
         BasedOn="{StaticResource LiquidGlassDrawerFlyoutPresenterStyle}">
    <Setter Property="utu:DrawerFlyoutPresenter.OpenDirection" Value="Up" />
  </Style>

  <Style x:Key="LiquidGlassToolkitLoadingViewStyle"
         TargetType="utu:LoadingView"
         BasedOn="{StaticResource DefaultLoadingView}">
    <Setter Property="Foreground" Value="{ThemeResource UnoToolkitGlassTint}" />
  </Style>
  <Style x:Key="LiquidGlassToolkitExtendedSplashScreenStyle"
         TargetType="utu:ExtendedSplashScreen"
         BasedOn="{StaticResource DefaultExtendedSplashScreen}">
    <Setter Property="Background" Value="{ThemeResource UnoToolkitGlassSurface}" />
    <Setter Property="Foreground" Value="{ThemeResource UnoToolkitGlassTint}" />
  </Style>

</ResourceDictionary>
